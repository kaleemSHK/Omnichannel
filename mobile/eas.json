{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_CHATWOOT_URL": "http://192.168.1.9:3000",
        "EXPO_PUBLIC_GATEWAY_URL": "http://192.168.1.9:80",
        "EXPO_PUBLIC_WS_URL": "ws://192.168.1.9/cable",
        "EXPO_PUBLIC_SIP_WSS": "wss://192.168.1.9:8089",
        "EXPO_PUBLIC_SIP_DOMAIN": "blinkone.local",
        "EXPO_PUBLIC_SIP_PASS": "blinkone-agent-demo",
        "EXPO_PUBLIC_STUN": "stun:stun.l.google.com:19302",
        "EXPO_PUBLIC_SUPPORT_QUEUE": "support",
        "EXPO_PUBLIC_SUPPORT_EXT": "5000",
        "EXPO_PUBLIC_DEFAULT_LANG": "ar"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
