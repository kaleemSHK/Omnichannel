# BlinkOne Platform — Environment Configuration
# Copy to .env and fill in real values before running docker compose up

# ─── Public URLs (default ports) ─────────────────────────────────────────────
# Chatwoot Rails UI + auth redirects
FRONTEND_URL=http://127.0.0.1:3000
# Next.js agent UI (Docker blinkone-frontend)
BLINKONE_AGENT_URL=http://127.0.0.1
# API gateway nginx (sidecars, /api/auth/token, telephony WSS)
BLINKONE_API_URL=http://127.0.0.1:8080

# Baked into blinkone-frontend image at build time
NEXT_PUBLIC_CHATWOOT_URL=http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8080
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:3000/cable
NEXT_PUBLIC_SIP_WSS=ws://127.0.0.1:8080/telephony/wss
NEXT_PUBLIC_SIP_DOMAIN=blinkone.local

# ─── Chatwoot (BlinkOne core) ────────────────────────────────────────────────
# Pin CE image — see docs/blinkone/UPSTREAM_BASE.md (never use :latest in prod)
# Built locally: docker/chatwoot-blinkone/Dockerfile → blinkone/chatwoot:v4.13.0-ce-b1
CHATWOOT_IMAGE=blinkone/chatwoot:v4.13.0-ce-b1
DISABLE_TELEMETRY=true
SECRET_KEY_BASE=replace-with-64-char-hex-secret
INSTALLATION_NAME=BlinkOne
INSTALLATION_EMAIL=admin@blinkone.ai
MAILER_SENDER_EMAIL=noreply@blinkone.ai

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=strong_password_here
APP_DB_PASSWORD=app_password_here

# ─── Redis ────────────────────────────────────────────────────────────────────
# (no password needed for local dev)

# ─── Gateway / JWT ────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-strong-jwt-secret

# ─── Service API Tokens (shared secret between gateway and each service) ──────
PLATFORM_TOKEN=platform-api-token
TENANT_TOKEN=tenant-api-token
# Chatwoot Platform App token (provision accounts — Prompt 8)
CHATWOOT_PLATFORM_TOKEN=
ACME_STUB=1
BLINKONE_DOMAIN_SUFFIX=blinkone.local
BLINKONE_CNAME_TARGET=ingress.blinkone.ai
TICKET_TOKEN=ticket-api-token
AI_TOKEN=ai-api-token
BILLING_TOKEN=billing-api-token
# Billing (Prompt 9 — OMR, 5% VAT, invoice template)
LABBIK_CR_NUMBER=CR-XXXX
LABBIK_VAT_NUMBER=VAT-XXXX
PSP_WEBHOOK_SECRET=
SLA_TOKEN=sla-api-token
ESCALATION_TOKEN=escalation-api-token
IVR_TOKEN=ivr-api-token
# Sidecar DB (ivr, audit, future Nest services) — host is postgres_app in compose
# BLINKONE_DATABASE_URL=postgresql://app:app_password_here@postgres_app:5432/blinkone_app
ROUTING_TOKEN=routing-api-token
RECORDING_TOKEN=recording-api-token
INTEGRATION_TOKEN=integration-api-token
CALLS_TOKEN=calls-api-token
WHATSAPP_CALLS_TOKEN=
WHATSAPP_CALLING_ENABLED=0
META_VERIFY_TOKEN=blinkone-meta-verify

# ─── AI (Prompt 7 — services/ai) ─────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
GOOGLE_STT_STUB=1
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-stt-sa.json
# GOOGLE_STT_PROJECT_ID=
PIPER_DEFAULT_VOICE=ar_JO-kareem-medium
MINIO_ROOT_USER=blinkone
MINIO_ROOT_PASSWORD=blinkone-minio-secret
CHATWOOT_BOT_TOKEN=

# ─── Chatwoot webhook secret ─────────────────────────────────────────────────
CHATWOOT_WEBHOOK_SECRET=
KEYCLOAK_STUB=1
KEYCLOAK_URL=http://blinkone-keycloak:8080

# ─── Telephony (Prompt 5 + 16 — profile telephony) ─────────────────────────
# TELEPHONY_EXTERNAL_IP=203.0.113.10
# TELEPHONY_LOCAL_NET=172.16.0.0/12
# TELEPHONY_SIP_DOMAIN=blinkone.local
# AST_ARI_USER=blinkone
# AST_ARI_PASS=blinkone-ari-secret
# AST_AGENT_SIP_PASS=blinkone-agent-demo
# AST_TRUNK_SIP_PASS=blinkone-trunk-demo
# AST_WSS_DOMAIN=blinkone.local
# ASTERISK_ARI_ENABLED=1
# IVR_WELCOME_MEDIA=sound:hello-world

# ─── Twilio SIP Trunk (Prompt 16 — demo PSTN) ────────────────────────────────
# TWILIO_SIP_HOST=demo.pstn.twilio.com
# TWILIO_DID=+12125551234

# ─── ngrok (Android demo — no public IP; update after ngrok start) ─────────────
# NGROK_SIP_HOST=0.tcp.ngrok.io
# NGROK_SIP_PORT=12345
# NGROK_WEB_DOMAIN=yourname.ngrok-free.app
# NGROK_WSS_HOST=0.tcp.ngrok.io
# NGROK_WSS_PORT=12346

# ─── Backups (scripts/blinkone/backup-production.sh) ─────────────────────────
# BLINKONE_BACKUP_DIR=./backups
# BLINKONE_BACKUP_BUCKET=s3://your-bucket   # or mc alias path
# AGE_RECIPIENT=age1...                      # encrypt .env.production in backups
