{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "BlinkOne CCaaS — service health, call metrics, tickets, AI usage",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🔁 HTTP Traffic",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (service) (rate(blinkone_http_requests_total[1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Requests/s by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (service, le) (rate(blinkone_http_request_duration_ms_bucket[5m])))",
          "legendFormat": "p95 {{service}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (service, le) (rate(blinkone_http_request_duration_ms_bucket[5m])))",
          "legendFormat": "p50 {{service}}",
          "refId": "B"
        }
      ],
      "title": "Request Latency p50/p95 (ms)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (service, status) (rate(blinkone_http_requests_total{status=~\"4..|5..\"}[1m]))",
          "legendFormat": "{{service}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Error Rate (4xx/5xx) by Service",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 200,
      "title": "📞 Calls",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 18 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "targets": [{ "expr": "sum(blinkone_calls_active)", "legendFormat": "Active", "refId": "A" }],
      "title": "Active Calls",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 18 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area" },
      "targets": [{ "expr": "sum(increase(blinkone_calls_total[1h]))", "legendFormat": "Calls/hr", "refId": "A" }],
      "title": "Calls (last 1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 6,
      "targets": [
        { "expr": "sum by (outcome) (increase(blinkone_calls_total[5m]))", "legendFormat": "{{outcome}}", "refId": "A" }
      ],
      "title": "Call Outcomes (5m rate)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 300,
      "title": "🎯 Routing Queues",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 7,
      "targets": [
        { "expr": "blinkone_queue_depth", "legendFormat": "{{queue_key}} ({{tenant}})", "refId": "A" }
      ],
      "title": "Queue Depth by Queue",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 400,
      "title": "🎫 Tickets",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "id": 8,
      "targets": [
        { "expr": "sum by (status) (increase(blinkone_tickets_total[5m]))", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "title": "Tickets Created (5m rate) by Status",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
      "id": 500,
      "title": "🤖 AI / Voicebot",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 45 },
      "id": 9,
      "targets": [
        { "expr": "sum by (tenant) (rate(blinkone_ai_tokens_total[5m]))", "legendFormat": "{{tenant}}", "refId": "A" }
      ],
      "title": "LLM Tokens/s by Tenant",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 45 },
      "id": 10,
      "options": { "colorMode": "background", "graphMode": "none" },
      "targets": [{ "expr": "sum(blinkone_voicebot_sessions_active)", "legendFormat": "Active Sessions", "refId": "A" }],
      "title": "Active Voicebot Sessions",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 53 },
      "id": 600,
      "title": "⚙️ Process Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "decbytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 54 },
      "id": 11,
      "targets": [
        { "expr": "process_memory_rss_bytes", "legendFormat": "RSS {{service}}", "refId": "A" },
        { "expr": "process_memory_heap_used_bytes", "legendFormat": "Heap {{service}}", "refId": "B" }
      ],
      "title": "Memory Usage by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 54 },
      "id": 12,
      "targets": [
        { "expr": "process_uptime_seconds", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "title": "Process Uptime (seconds)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["blinkone", "ccaas", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "BlinkOne CCaaS Overview",
  "uid": "blinkone-overview",
  "version": 1
}
