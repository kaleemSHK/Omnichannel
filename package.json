{
  "name": "blinkone",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "seed:sla": "node scripts/seed-sla.mjs",
    "seed:demo": "node scripts/seed-demo-sidecars.mjs",
    "seed:client-demo": "node scripts/seed-client-demo.mjs",
    "test:acceptance": "node tests/acceptance/runner.mjs",
    "test:acceptance:full": "node tests/acceptance/runner.mjs --all-tr",
    "security:audit": "node scripts/blinkone/security-audit.mjs",
    "docs:build": "mkdocs build -f mkdocs.yml"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
