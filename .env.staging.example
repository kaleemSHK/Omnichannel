# BlinkOne staging — copy to .env.staging
# Use DIFFERENT secrets than production.

FRONTEND_URL=http://localhost:8080

SECRET_KEY_BASE=staging-replace-with-64-char-hex-secret
INSTALLATION_NAME=BlinkOne (Staging)
INSTALLATION_EMAIL=admin-staging@blinkone.ai
MAILER_SENDER_EMAIL=noreply-staging@blinkone.ai

POSTGRES_PASSWORD=staging_postgres_password
APP_DB_PASSWORD=staging_app_password

JWT_SECRET=staging-jwt-secret

# Pin same Chatwoot CE image as production (see docs/blinkone/UPSTREAM_BASE.md)
CHATWOOT_IMAGE=chatwoot/chatwoot:v4.13.0-ce

PLATFORM_TOKEN=staging-platform-token
TICKET_TOKEN=staging-ticket-token
AI_TOKEN=staging-ai-token
BILLING_TOKEN=staging-billing-token
SLA_TOKEN=staging-sla-token
ESCALATION_TOKEN=staging-escalation-token
IVR_TOKEN=staging-ivr-token
ROUTING_TOKEN=staging-routing-token
RECORDING_TOKEN=staging-recording-token
INTEGRATION_TOKEN=staging-integration-token
CALLS_TOKEN=staging-calls-token

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CHATWOOT_WEBHOOK_SECRET=
