Section 3 — Sentiment + Summary:
- Positive=green / Neutral=gray / Negative=red badge
- "Summarize" button → summarizeConversation(conversationId) → modal

>> useConversations.ts:
export function useConversations(filters) {
  return useInfiniteQuery({
    queryKey: ['conversations', filters],
    queryFn: ({ pageParam = 1 }) => listConversations({ ...filters, page: pageParam }),
    getNextPageParam: (last) => last.meta.next_page ?? undefined,
  })
}
export function useMessages(conversationId) {
  return useQuery({
    queryKey: ['messages', conversationId],
    queryFn: () => getMessages(conversationId),
    enabled: !!conversationId,
  })
}

