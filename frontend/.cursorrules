━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
API BASE URLS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_API_BASE = http://localhost (or domain in prod)

Chatwoot REST (use cwFetch — never raw fetch):
  GET/POST  {BASE}/api/v1/accounts/{accountId}/conversations
  GET/POST  {BASE}/api/v1/accounts/{accountId}/contacts
  GET/POST  {BASE}/api/v1/accounts/{accountId}/messages
  GET       {BASE}/api/v2/accounts/{accountId}/conversations  (paginated)
  Auth header: api_access_token: <chatwoot_user_token>

BlinkOne sidecars (use bnFetch — never raw fetch):
  {BASE}/api/calls/*         → calls sidecar
  {BASE}/api/routing/*       → routing sidecar
  {BASE}/api/sla/*           → SLA sidecar
  {BASE}/api/ivr/*           → IVR sidecar
  {BASE}/api/ai/*            → AI sidecar
  {BASE}/api/billing/*       → billing sidecar
  {BASE}/api/tickets/*       → tickets sidecar
  {BASE}/api/escalations/*   → escalation sidecar
  {BASE}/api/platform/*      → platform sidecar
  {BASE}/api/recordings/*    → recording sidecar
  Auth header: Authorization: Bearer <gateway_jwt>

Action Cable WebSocket:
  ws://{BASE}/cable?access_token=<chatwoot_token>
  Channels: RoomChannel, NotificationsChannel, BlinkoneCallChannel

Asterisk WSS (JsSIP):
  wss://{BASE}/telephony/wss
  Credentials: GET /api/routing/v1/agents/{agentId}/webrtc

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
AUTH FLOW
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
1. POST /auth/sign_in → { data: { access_token, id, name, email, role, account_id } }
2. POST /api/auth/token (header: api_access_token) → { token: <gateway_jwt>, expiresIn }
3. Store both in Zustand useAuthStore (memory only — no localStorage)
4. cwFetch() auto-sends api_access_token header
5. bnFetch() auto-sends Authorization: Bearer header

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
HARD RULES — NEVER BREAK THESE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
1.  NEVER use localStorage or sessionStorage — tokens in Zustand memory only
2.  NEVER hardcode colors — use Tailwind tokens or CSS vars (--brand-primary etc.)
3.  NEVER call Chatwoot API with raw fetch — always use cwFetch() from client.ts
4.  NEVER call sidecar APIs with raw fetch — always use bnFetch() from client.ts
5.  NEVER use `any` type — use proper types from src/types/index.ts
6.  Every page component: async server component UNLESS needs client state → 'use client'
7.  Every API call through TanStack Query (useQuery/useMutation) — no raw useEffect fetches
8.  All forms use react-hook-form + zod schema validation
9.  Arabic RTL: dir="auto" on message content, logical CSS (start/end not left/right)
10. Sidecar tenant_id context: handled by bnFetch via JWT — do NOT add manually
11. Do NOT modify src/lib/api/*.ts or src/types/index.ts
12. Do NOT touch anything outside frontend/ directory
13. Loading states: shadcn Skeleton — never a spinner for list/table loads
14. Error states: inline error card with retry button — never just console.log
15. Use ms-* / me-* (margin-start/end) — not ml-*/mr-* — for RTL compatibility
16. Icons: lucide-react ONLY — never import from any other icon library

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
BRAND TOKENS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Product:        BlinkOne
Company:        LABBIK Telecom S.P.C
Primary color:  #0B5FFF  → Tailwind: brand-primary (text-brand-primary, bg-brand-primary)
Ink color:      #0A0F1C  → Tailwind: brand-ink
Font:           Inter (LTR) / Noto Sans Arabic (RTL)
Border radius:  rounded-lg (cards) · rounded-md (inputs/badges)

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
COMPONENT PATTERNS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Query pattern (always use):
  const { data, isLoading, error } = useQuery({
    queryKey: ['key', filters],
    queryFn: () => apiFn(filters),
    refetchInterval: 30_000,
  })

Mutation pattern:
  const mutation = useMutation({
    mutationFn: (data) => apiCall(data),
    onSuccess: () => queryClient.invalidateQueries({ queryKey: ['key'] }),
    onError: (err) => toast.error(err.message),
  })

Infinite scroll pattern:
  useInfiniteQuery({
    queryKey: ['key', filters],
    queryFn: ({ pageParam = 1 }) => apiFn({ ...filters, page: pageParam }),
    getNextPageParam: (last) => last.meta.next_page ?? undefined,
  })

RTL pattern:
  <div className="flex gap-3 rtl:flex-row-reverse">
  <p dir="auto" className="text-sm">  ← CRITICAL for Arabic
  Use ms-* / me-* (never ml-* / mr-*)

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
