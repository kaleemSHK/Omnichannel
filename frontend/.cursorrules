blinkone-frontend:
  build: { context: ./frontend, dockerfile: Dockerfile }
  restart: unless-stopped
  environment:
    NEXT_PUBLIC_API_BASE: ${FRONTEND_URL:-http://localhost}
    NEXT_PUBLIC_WS_URL: ws://localhost/cable
    NEXT_PUBLIC_SIP_WSS: wss://localhost/telephony/wss
    NEXT_PUBLIC_SIP_DOMAIN: blinkone.local
  ports: ["3001:3001"]
  networks: [blinkone]
