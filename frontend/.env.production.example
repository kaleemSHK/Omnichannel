# Copy to .env.production on the server before `npm run build` (file is gitignored).

NEXT_PUBLIC_CHATWOOT_URL=https://app.blinksone.com
NEXT_PUBLIC_API_BASE=https://app.blinksone.com
NEXT_PUBLIC_WS_URL=wss://app.blinksone.com/cable

# Twilio Elastic SIP Trunk (optional — leave SIP_PASS empty for UI-only demo)
NEXT_PUBLIC_SIP_WSS=wss://sip.twilio.com:5061
NEXT_PUBLIC_SIP_DOMAIN=your-trunk.pstn.twilio.com
NEXT_PUBLIC_SIP_USER=your_credential_username
NEXT_PUBLIC_SIP_PASS=your_credential_password

NEXT_PUBLIC_USE_DEMO_DATA=false
