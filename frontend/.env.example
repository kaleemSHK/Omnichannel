# BlinkOne Frontend — copy to .env.local for local dev

# Same-origin proxies (avoids CORS); next.config rewrites:
#   /_cw → Chatwoot :3000
#   /_gw → Gateway (default :8080; use GATEWAY_UPSTREAM=http://127.0.0.1:80 if nginx is on :80)
NEXT_PUBLIC_CHATWOOT_URL=/_cw
NEXT_PUBLIC_API_BASE=/_gw

# Server-side rewrites (required when NEXT_PUBLIC_* use /_cw and /_gw):
#   CHATWOOT_UPSTREAM=http://127.0.0.1:3000
#   GATEWAY_UPSTREAM=http://127.0.0.1:8787   # direct gateway — NOT :80 (nginx may HTTPS-redirect)
# PowerShell local dev example:
#   $env:CHATWOOT_UPSTREAM="http://127.0.0.1:3000"
#   $env:GATEWAY_UPSTREAM="http://127.0.0.1:8787"

# Keycloak OIDC — for SSO login
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=blinkone
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=blinkone-frontend

# Chatwoot Action Cable (use :3000 in local dev, or :80/cable via nginx)
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:3000/cable
NEXT_PUBLIC_SIP_WSS=ws://127.0.0.1/telephony/wss
NEXT_PUBLIC_SIP_DOMAIN=blinkone.local
NEXT_PUBLIC_SIP_USER=agent
NEXT_PUBLIC_SIP_PASS=blinkone-agent-demo

NEXT_PUBLIC_FEATURE_PSTN=true
NEXT_PUBLIC_FEATURE_WHATSAPP_CALLING=true
NEXT_PUBLIC_FEATURE_AI_ASSIST=true
NEXT_PUBLIC_FEATURE_VOICE_BOT=true

# false = live Chatwoot inbox + gateway APIs; true = fixture data for UI dev
NEXT_PUBLIC_USE_DEMO_DATA=false
